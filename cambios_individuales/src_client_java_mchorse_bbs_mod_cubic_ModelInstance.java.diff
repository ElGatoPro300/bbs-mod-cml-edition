     public ModelInstance(String id, IModel model, Animations animations, Link texture)
     {
         this.id = id;
         this.model = model;
         this.animations = animations;
         this.texture = texture;
 
         this.poseGroup = id;
     }
 
     @Override
     public IModel getModel()
     {
